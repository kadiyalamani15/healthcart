# Groq — free tier, no credit card required (required)
# Sign up at console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# Langfuse (required for tracing + eval)
# Create a free project at https://cloud.langfuse.com or https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com

# USDA FoodData Central — free, no approval process (optional but recommended)
# Sign up at https://fdc.nal.usda.gov/api-key-signup/
# Falls back to the shared "DEMO_KEY" if unset — heavily rate-limited,
# fine for local testing, not for real use.
USDA_FDC_API_KEY=
